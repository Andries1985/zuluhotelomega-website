    <item>
      <title>Protection Modifiers</title>
      <link>https://zuluhotelomega.com/infovault/items/protectionmods/</link>
      <pubDate>Sun, 17 Nov 2024 11:47:31 +0100</pubDate>
      <guid>https://zuluhotelomega.com/infovault/items/protectionmods/</guid>
      <description>&lt;h2 id=&#34;melee-protection&#34;&gt;Melee protection&lt;/h2&gt;&#xA;&#xA;&lt;div class=&#34;table-responsive&#34;&gt;&#xA;  &lt;table class=&#34;table table-bordered table-hover table-striped&#34;&gt;&#xA;      &lt;thead&#xA;        &gt;&#xA;          &lt;tr&gt;&#xA;              &lt;th&#xA;                &gt;Suffix&lt;/th&gt;&#xA;              &lt;th&#xA;                &gt;Protection level&lt;/th&gt;&#xA;          &lt;/tr&gt;&#xA;      &lt;/thead&gt;&#xA;    &lt;tbody&#xA;      &gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Protection&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;1&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Stoneskin&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;2&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Unmovable Stone&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;3&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Adamantine Shielding&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;4&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Mystical Cloaks&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;5&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Holy Auras&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;6&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Pain&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-1&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Bleeding&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-2&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Rending&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-3&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Tearing&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-4&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Shredding&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-5&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Peril&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-6&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;    &lt;/tbody&gt;&#xA;  &lt;/table&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;fire-water-air-earth-protections&#34;&gt;Fire, Water, Air, Earth protections&lt;/h2&gt;&#xA;&lt;p&gt;Where XXX is the elements name.&lt;/p&gt;&#xA;&#xA;&lt;div class=&#34;table-responsive&#34;&gt;&#xA;  &lt;table class=&#34;table table-bordered table-hover table-striped&#34;&gt;&#xA;      &lt;thead&#xA;        &gt;&#xA;          &lt;tr&gt;&#xA;              &lt;th&#xA;                &gt;Suffix&lt;/th&gt;&#xA;              &lt;th&#xA;                &gt;Protection level&lt;/th&gt;&#xA;          &lt;/tr&gt;&#xA;      &lt;/thead&gt;&#xA;    &lt;tbody&#xA;      &gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Bane&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;25%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Warding&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;50%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Protection&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;65%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Immunity&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;75%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Attunement&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;85%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Absorbsion&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;95%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Weakness&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-25%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Vulnerability&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-50%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Amplification&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-75%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Defenselessness&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-100%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Exposure&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-125%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;        &lt;tr&gt;&#xA;            &lt;td&#xA;              &gt;Elemental XXX Endangerment&lt;/td&gt;&#xA;            &lt;td&#xA;              &gt;-150%&lt;/td&gt;&#xA;        &lt;/tr&gt;&#xA;    &lt;/tbody&gt;&#xA;  &lt;/table&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;necro-protection&#34;&gt;Necro protection&lt;/h2&gt;&#xA;&#xA;&lt;div class=&#34;table-responsive&#34;&gt;&#xA;  &lt;table class=&#34;table table-bordered table-hover table-striped&#34;&gt;&#xA;      &lt;thead&#xA;        &gt;&#xA;          &lt;tr&gt;&#xA;              &lt;th&#xA;                &gt;Suffix&lt;/th&gt;&#xA;              &lt;th&#xA;                &gt;Protection level&lt;/th&gt;&#xA;          &lt;/tr&gt;&#x